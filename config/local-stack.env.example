# Copy this file to config/local-stack.env and adjust for your machine.

# OpenClaw runtime state lives outside the repo by default.
OPENCLAW_HOME="$HOME/.openclaw"
OPENCLAW_STATE_DIR="$HOME/.openclaw"
OPENCLAW_CONFIG_PATH="$HOME/.openclaw/openclaw.json"

# Gateway runtime controlled from this repository.
AGENTWORKROOM_GATEWAY_HOST="127.0.0.1"
AGENTWORKROOM_GATEWAY_PORT="18789"
AGENTWORKROOM_GATEWAY_BIND="loopback"
AGENTWORKROOM_GATEWAY_FORCE="1"
AGENTWORKROOM_GATEWAY_LOG=".agentworkroom/logs/gateway.log"
AGENTWORKROOM_GATEWAY_PIDFILE=".agentworkroom/run/gateway.pid"

# Optional repo build behavior.
AGENTWORKROOM_BOOTSTRAP_BUILD="1"
AGENTWORKROOM_BOOTSTRAP_UI_BUILD="1"

# Ollama checks.
AGENTWORKROOM_OLLAMA_URL="http://127.0.0.1:11434"
AGENTWORKROOM_REQUIRED_TEXT_MODEL="gemma4-openclaw:latest"
AGENTWORKROOM_REQUIRED_IMAGE_MODEL="qwen3-vl:8b"

# Existing external services you want the repo to monitor.
AGENTWORKROOM_HOME_ASSISTANT_URL="http://127.0.0.1:8123"
AGENTWORKROOM_N8N_URL="http://127.0.0.1:5678"

# Optional compose ownership. Only set these if you want AgentWorkroom to start/stop them.
# AGENTWORKROOM_MANAGE_HOME_ASSISTANT="1"
# AGENTWORKROOM_HOME_ASSISTANT_COMPOSE="/absolute/path/to/homeassistant/docker-compose.yml"
# AGENTWORKROOM_MANAGE_N8N="1"
# AGENTWORKROOM_N8N_COMPOSE="/absolute/path/to/n8n/docker-compose.yml"
